# =============================================================================
# Kraionyx - Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in production values.
#   cp .env.example .env
#
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Infrastructure
# -----------------------------------------------------------------------------
REDIS_PASSWORD=change_me_in_production
KAFKA_BROKERS=kafka-broker:9092

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=generate-a-32-byte-base64-key-here
# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_in_production
API_KEY=change_me_in_production

# TLS certificate paths (mounted read-only in containers)
TLS_CERT_PATH=/certs/cert.pem
TLS_KEY_PATH=/certs/key.pem

# -----------------------------------------------------------------------------
# HuggingFace (for pyannote speaker diarization + MedGemma)
# -----------------------------------------------------------------------------
# Obtain from https://huggingface.co/settings/tokens
# Requires accept of model licenses for pyannote/speaker-diarization-3.1
# and google/medgemma-4b-it
HF_TOKEN=your_huggingface_token_here

# -----------------------------------------------------------------------------
# FHIR / EHR Integration
# -----------------------------------------------------------------------------
FHIR_SERVER_URL=http://hapi-fhir:8080/fhir
FHIR_CLIENT_ID=your_client_id
FHIR_CLIENT_SECRET=your_client_secret

# -----------------------------------------------------------------------------
# Service Configuration
# -----------------------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=debug

# API Gateway
API_GATEWAY_PORT=8443

# STT Engine (faster-whisper)
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16
WHISPER_BEAM_SIZE=5
WHISPER_LANGUAGE=en

# Clinical NLP (MedGemma)
MEDGEMMA_MODEL=google/medgemma-4b-it
MEDGEMMA_MAX_TOKENS=2048
MEDGEMMA_TEMPERATURE=0.3

# Audio Processor
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
AUDIO_BIT_DEPTH=16
AUDIO_CHUNK_DURATION_MS=5000

# Redis Streams
REDIS_STREAM_MAX_LEN=10000
REDIS_AUDIO_BUFFER_TTL_SECONDS=3600
